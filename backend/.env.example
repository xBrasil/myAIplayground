APP_NAME=My AI Playground
APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8000
DATABASE_URL=sqlite:///../data/app.db
UPLOAD_DIR=../data/uploads
MODEL_CACHE_DIR=../data/model-cache
ENABLE_MODEL_LOADING=true
DEFAULT_MODEL_KEY=e2b
DEFAULT_SYSTEM_PROMPT=You are a helpful and precise LOCAL assistant.
PREFERRED_TTS_VOICE=Microsoft Antonio

# GGUF model repos (HuggingFace)
GGUF_REPO_E2B=unsloth/gemma-4-E2B-it-GGUF
GGUF_REPO_E4B=unsloth/gemma-4-E4B-it-GGUF
GGUF_REPO_26B=unsloth/gemma-4-26B-A4B-it-GGUF

# GGUF model filenames (adjust quantization as needed)
GGUF_FILE_E2B=gemma-4-E2B-it-Q8_0.gguf
GGUF_FILE_E4B=gemma-4-E4B-it-Q4_K_M.gguf
GGUF_FILE_26B=gemma-4-26B-A4B-it-UD-IQ4_XS.gguf

# Vision projector files (empty = no vision for that model)
MMPROJ_FILE_E2B=mmproj-F16.gguf
MMPROJ_FILE_E4B=mmproj-F16.gguf
MMPROJ_FILE_26B=mmproj-F16.gguf

# llama.cpp engine
N_CTX=0
N_GPU_LAYERS=-1
FLASH_ATTN=true
LLAMA_SERVER_HOST=127.0.0.1
LLAMA_SERVER_PORT=8081
IMAGE_MIN_TOKENS=280
IMAGE_MAX_TOKENS=512

# Whisper ASR model size (tiny, base, small, medium, large-v3)
WHISPER_MODEL_SIZE=base
